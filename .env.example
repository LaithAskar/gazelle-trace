# Required for live GPT-5.6 analysis. Without it the app uses its deterministic demo pipeline.
OPENAI_API_KEY=

# GPT-5.6 Sol is used for the primary diagnosis; Terra is used as the independent verifier.
OPENAI_PRIMARY_MODEL=gpt-5.6
OPENAI_VERIFIER_MODEL=gpt-5.6-terra

# Leave true for a submission that must remain judgeable if the API is unavailable.
ENABLE_DEMO_FALLBACK=true

